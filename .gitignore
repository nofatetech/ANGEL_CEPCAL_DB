# Raw congress source media — kept local, not in the DB repo (large binaries).
# Transcripts under Videos_CEPCAL_2026/transcript/ ARE tracked (they are the data).
*.zip
*.mp4
Videos_CEPCAL_2026/*.mp4

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
# Obsidian: track the curated vault config (graph colors, plugins, appearance)
# so the experience travels with the repo; ignore only per-machine UI state.
**/.obsidian/workspace.json
**/.obsidian/workspace-mobile.json
**/.obsidian/cache
